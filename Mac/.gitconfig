[user]
	email = willywcliu@going.cloud
	name = WillyLiu

[merge]
    tool = vscode
[mergetool "vscode"]
    cmd = code --wait $MERGED

[diff]
    tool = vscode
[difftool]
    prompt = false
[difftool "vscode"]
    cmd = code --wait --diff $LOCAL $REMOTE

[include]
	path = ~/.gitalias

[credential]
	helper = store
